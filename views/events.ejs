<section class="hero">
    <div class="container">
        <h2>Zion's Tank Events & Networking</h2>
        <p>Connect with fellow business leaders through exclusive networking events, workshops, and seminars designed to foster collaboration and growth.</p>
        <div class="hero-actions">
            <button id="create-event-btn" class="cta-button">Create Event</button>
            <button id="my-events-btn" class="cta-button button-secondary">My Events</button>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <!-- View Toggle Buttons -->
        <div class="toggle-wrap">
            <div class="toggle-group">
                <button id="list-view-btn-1" class="view-toggle-btn active">
                    <i class="fas fa-list"></i> List View
                </button>
                <button id="calendar-view-btn-1" class="view-toggle-btn">
                    <i class="fas fa-calendar-alt"></i> Calendar View
                </button>
            </div>
        </div>

        <!-- Search and Filter Bar -->
        <div class="filter-panel">
            <div class="filter-grid">
                <div class="filter-field">
                    <label for="search-input">Search Events</label>
                    <input type="text" id="search-input" placeholder="Search events..." class="filter-control">
                </div>
                <div class="filter-field">
                    <label for="event-type-filter">Event Type</label>
                    <select id="event-type-filter" class="filter-control">
                        <option value="">All Types</option>
                        <option value="networking">Networking</option>
                        <option value="workshop">Workshop</option>
                        <option value="seminar">Seminar</option>
                        <option value="social">Social</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div class="filter-field">
                    <label for="date-filter">Date Range</label>
                    <select id="date-filter" class="filter-control">
                        <option value="">All Dates</option>
                        <option value="today">Today</option>
                        <option value="week">This Week</option>
                        <option value="month">This Month</option>
                        <option value="upcoming">Upcoming</option>
                    </select>
                </div>
                <div class="filter-field">
                    <button id="search-btn" class="cta-button filter-submit">Search</button>
                </div>
            </div>
        </div>

        <!-- Events Container -->
        <div id="events-view" class="view-container">
            <h3 class="section-subheading">Upcoming Events</h3>
            <div id="events-list" class="cards-grid cards-grid-lg">
                <!-- Events will be loaded here -->
            </div>
        </div>

        <!-- Calendar View Container -->
        <div id="calendar-view" class="view-container is-hidden">
            <div id="calendar-container">
                <!-- Calendar will be loaded here -->
            </div>
        </div>

    </div>
</section>
