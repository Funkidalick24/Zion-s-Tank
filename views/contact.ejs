<section id="contact" class="section">
    <div class="container">
        <h2>Contact Us</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 3rem; margin-top: 3rem;">
            <div>
                <h3 style="color: #003366; margin-bottom: 1rem;">Get In Touch</h3>
                <div style="display: flex; align-items: center; margin-bottom: 1rem;">
                    <i class="fas fa-map-marker-alt" style="color: #D4AF37; margin-right: 1rem; font-size: 1.2rem;"></i>
                    <div>
                        <strong>Address</strong><br>
                        123 Business District<br>
                        City, State 12345
                    </div>
                </div>
                <div style="display: flex; align-items: center; margin-bottom: 1rem;">
                    <i class="fas fa-phone" style="color: #D4AF37; margin-right: 1rem; font-size: 1.2rem;"></i>
                    <div>
                        <strong>Phone</strong><br>
                        (555) 123-4567
                    </div>
                </div>
                <div style="display: flex; align-items: center; margin-bottom: 1rem;">
                    <i class="fas fa-envelope" style="color: #D4AF37; margin-right: 1rem; font-size: 1.2rem;"></i>
                    <div>
                        <strong>Email</strong><br>
                        info@zionstank.org
                    </div>
                </div>
            </div>
            <div>
                <h3 style="color: #003366; margin-bottom: 1rem;">Office Hours</h3>
                <div style="line-height: 1.8;">
                    <strong>Monday - Friday:</strong> 8:00 AM - 5:00 PM<br>
                    <strong>Saturday:</strong> 9:00 AM - 1:00 PM<br>
                    <strong>Sunday:</strong> Closed
                </div>
                <div style="margin-top: 2rem;">
                    <h4 style="color: #003366; margin-bottom: 1rem;">Follow Us</h4>
                    <div style="display: flex; gap: 1rem;">
                        <a href="#" style="color: #003366; font-size: 1.5rem;"><i class="fab fa-facebook"></i></a>
                        <a href="#" style="color: #003366; font-size: 1.5rem;"><i class="fab fa-twitter"></i></a>
                        <a href="#" style="color: #003366; font-size: 1.5rem;"><i class="fab fa-linkedin"></i></a>
                        <a href="#" style="color: #003366; font-size: 1.5rem;"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
            <div>
                <h3 style="color: #003366; margin-bottom: 1rem;">Send us a Message</h3>
                <form id="contact-form">
                    <div class="form-group">
                        <label for="contact-name">Name</label>
                        <input type="text" id="contact-name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="contact-email">Email</label>
                        <input type="email" id="contact-email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="contact-subject">Subject</label>
                        <input type="text" id="contact-subject" name="subject" required>
                    </div>
                    <div class="form-group">
                        <label for="contact-message">Message</label>
                        <textarea id="contact-message" name="message" rows="5" required></textarea>
                    </div>
                    <button type="submit" class="cta-button">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</section>