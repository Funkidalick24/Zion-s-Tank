<section id="home" class="hero">
    <div class="container">
        <h2>Empowering Business Through Trusted Connections</h2>
        <p>Zion's Tank is dedicated to fostering growth, development, and prosperity through verified partnerships, exclusive networking opportunities, and advocacy for businesses.</p>
        <div class="hero-actions">
            <button class="cta-button" onclick="window.location.href='/register-step1'">Become a Member</button>
            <button class="cta-button button-secondary" onclick="window.location.href='/login'">Member Login</button>
        </div>
    </div>
</section>

<section id="about" class="section">
    <div class="container">
        <h2>About Zion's Tank</h2>
        <div class="value-grid">
            <div class="value-card">
                <i class="fas fa-bullseye value-icon"></i>
                <h3>Our Mission</h3>
                <p>To promote and protect the interests of businesses, fostering growth through collaboration, innovation, and advocacy.</p>
            </div>
            <div class="value-card">
                <i class="fas fa-eye value-icon"></i>
                <h3>Our Vision</h3>
                <p>To be the leading voice for business, creating a thriving ecosystem where businesses prosper and communities flourish.</p>
            </div>
            <div class="value-card">
                <i class="fas fa-handshake value-icon"></i>
                <h3>Our Values</h3>
                <p>Integrity, collaboration, innovation, and community commitment guide everything we do to support our members' success.</p>
            </div>
        </div>
    </div>
</section>

<section id="benefits" class="section">
    <div class="container">
        <h2>Featured Members</h2>
        <p>Meet some of our most trusted and verified business members.</p>
        <div class="cards-grid cards-grid-sm">
            <% featuredUsers.slice(0, 4).forEach(user => { %>
            <div class="showcase-card align-center">
                <% if (user.profileImageUrl) { %>
                <img src="<%= user.profileImageUrl %>" alt="<%= user.businessName %>" class="avatar-lg">
                <% } else { %>
                <div class="avatar-lg avatar-fallback">
                    <%= user.businessName ? user.businessName.charAt(0).toUpperCase() : '?' %>
                </div>
                <% } %>
                <h4 class="card-title"><%= user.businessName %></h4>
                <% if (user.businessDescription) { %>
                <p class="card-copy"><%= user.businessDescription.substring(0, 100) %>...</p>
                <% } %>
                <div class="pill-row center">
                    <span class="pill pill-trust">Trust: <%= user.trustScore || 0 %></span>
                </div>
            </div>
            <% }) %>
            <% if (featuredUsers.length === 0) { %>
            <div class="empty-state">
                <i class="fas fa-users empty-icon"></i>
                <p>Featured members will appear here once the community grows.</p>
            </div>
            <% } %>
        </div>
    </div>
</section>

<section id="marketplace" class="section">
    <div class="container">
        <h2>Featured Products</h2>
        <p>Discover products and services from our trusted member businesses.</p>
        <div class="cards-grid cards-grid-sm">
            <% featuredProducts.slice(0, 4).forEach(product => { %>
            <div class="showcase-card align-center">
                <% if (product.imageUrl) { %>
                <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="media-cover media-sm">
                <% } else { %>
                <div class="media-cover media-sm media-fallback">
                    <i class="fas fa-box"></i>
                </div>
                <% } %>
                <h4 class="card-title"><%= product.name %></h4>
                <% if (product.description) { %>
                <p class="card-copy"><%= product.description.substring(0, 80) %>...</p>
                <% } %>
                <div class="price-text">
                    <%= product.price ? '$' + product.price : 'Price on request' %>
                </div>
            </div>
            <% }) %>
            <% if (featuredProducts.length === 0) { %>
            <div class="empty-state">
                <i class="fas fa-shopping-cart empty-icon"></i>
                <p>Featured products will appear here as members list their items.</p>
            </div>
            <% } %>
        </div>
    </div>
</section>

<section id="cta" class="section cta-band">
    <div class="container">
        <h2>Ready to Join Our Business Community?</h2>
        <p>Become a member today and unlock exclusive benefits, networking opportunities, and resources to grow your business.</p>
        <div class="hero-actions">
            <button class="cta-button" onclick="window.location.href='/register-step1'">Join Now</button>
            <button class="cta-button button-accent-outline" onclick="window.location.href='/marketplace'">Explore Directory</button>
        </div>
    </div>
</section>

<section id="events" class="section">
    <div class="container">
        <h2>Upcoming Events</h2>
        <p>Join our upcoming events to network, learn, and grow your business.</p>
        <div class="cards-grid cards-grid-md">
            <% upcomingEvents.forEach(event => { %>
            <div class="showcase-card">
                <h4 class="card-title"><%= event.title %></h4>
                <p class="card-copy"><%= event.description %></p>
                <div class="meta-row">
                    <div class="meta-item">
                        <i class="fas fa-calendar"></i>
                        <%= event.eventDate ? (function() { try { return new Date(event.eventDate).toLocaleDateString(); } catch(e) { return 'TBD'; } })() : 'TBD' %>
                    </div>
                    <% if (event.location) { %>
                    <div class="meta-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <%= event.location %>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }) %>
            <% if (upcomingEvents.length === 0) { %>
            <div class="empty-state">
                <i class="fas fa-calendar empty-icon"></i>
                <p>No upcoming events scheduled. Check back soon!</p>
            </div>
            <% } %>
        </div>
    </div>
</section>
