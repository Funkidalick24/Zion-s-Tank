<section class="hero">
    <div class="container">
        <h2>Member Marketplace</h2>
        <p>Buy and sell products and services within our trusted community. All transactions are between verified members.</p>
        <div class="hero-actions">
            <button class="cta-button" onclick="window.location.href='/directory'">View Directory</button>
            <button class="cta-button button-secondary" onclick="document.getElementById('account-btn').click()">List Your Items</button>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <!-- Search and Filter Bar -->
        <div class="filter-panel">
            <div class="filter-grid">
                <div class="filter-field">
                    <label for="search-input">Search Products</label>
                    <input type="text" id="search-input" placeholder="Search products, services..." class="filter-control">
                </div>
                <div class="filter-field">
                    <label for="category-filter">Category</label>
                    <select id="category-filter" class="filter-control">
                        <option value="">All Categories</option>
                        <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>" <%= filters.category == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="filter-field">
                    <label for="price-filter">Price Range</label>
                    <select id="price-filter" class="filter-control">
                        <option value="">All Prices</option>
                        <option value="0-100">Under $100</option>
                        <option value="100-500">$100 - $500</option>
                        <option value="500-1000">$500 - $1,000</option>
                        <option value="1000-5000">$1,000 - $5,000</option>
                        <option value="5000+">$5,000+</option>
                    </select>
                </div>
                <div class="filter-field">
                    <button id="search-btn" class="cta-button filter-submit">Search</button>
                </div>
            </div>
        </div>

        <!-- Marketplace Products -->
        <div id="marketplace-view" class="view-container">
            <h3 class="section-subheading">Available Products & Services</h3>
            <div id="products-list" class="cards-grid cards-grid-md">
                <% products.forEach(product => { %>
                <div class="product-item showcase-card">
                        <% if (product.imageUrls && product.imageUrls.length > 0) { %>
                        <img src="<%= product.imageUrls[0] %>" alt="<%= product.name %>" class="media-cover media-md">
                        <% } else { %>
                        <div class="media-cover media-md media-fallback">
                            <i class="fas fa-box"></i>
                        </div>
                        <% } %>
                        <h4 class="card-title"><%= product.name %></h4>
                        <% if (product.description) { %>
                        <p class="card-copy"><%= product.description.substring(0, 100) %>...</p>
                        <% } %>
                        <div class="price-row">
                            <div class="price-text">
                                $<%= product.price %>
                            </div>
                            <% if (product.seller) { %>
                            <div class="card-meta">
                                by <%= product.seller.businessName || `${product.seller.firstName} ${product.seller.lastName}` %>
                            </div>
                            <% } %>
                        </div>
                        <div class="pill-row">
                            <% if (product.seller && product.seller.isVerified) { %>
                            <span class="pill pill-verified">Verified Seller</span>
                            <% } %>
                            <% if (product.category) { %>
                            <span class="pill pill-primary"><%= product.category.name %></span>
                            <% } %>
                        </div>
                </div>
                <% }) %>
                <% if (products.length === 0) { %>
                <div class="empty-state">
                    <i class="fas fa-shopping-cart empty-icon"></i>
                    <p>No products found matching your criteria.</p>
                </div>
                <% } %>
            </div>
            <% if (pagination.totalPages > 1) { %>
            <div class="pagination-wrap">
                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                <a href="?page=<%= i %><%= filters.q ? '&q=' + encodeURIComponent(filters.q) : '' %><%= filters.category ? '&category=' + filters.category : '' %><%= filters.price ? '&price=' + filters.price : '' %><%= filters.sort ? '&sort=' + filters.sort : '' %>"
                   class="pagination-link <%= i === pagination.currentPage ? 'active' : '' %>">
                    <%= i %>
                </a>
                <% } %>
            </div>
            <% } %>
        </div>
    </div>
</section>
