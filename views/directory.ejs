<section class="hero">
    <div class="container">
        <h2>Member Business Directory</h2>
        <p>Connect with verified members and discover trusted business partners in your community.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <!-- Search and Filter Bar -->
        <div style="background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,51,102,0.1); margin-bottom: 3rem;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; align-items: end;">
                <div>
                    <label for="search-input" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #003366;">Search</label>
                    <input type="text" id="search-input" placeholder="Search businesses, products..." style="width: 100%; padding: 0.8rem; border: 2px solid #E6F3FF; border-radius: 6px; font-size: 1rem;">
                </div>
                <div>
                    <label for="category-filter" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #003366;">Category</label>
                    <select id="category-filter" style="width: 100%; padding: 0.8rem; border: 2px solid #E6F3FF; border-radius: 6px; font-size: 1rem;">
                        <option value="">All Categories</option>
                        <option value="retail">Retail & Services</option>
                        <option value="professional">Professional Services</option>
                        <option value="manufacturing">Manufacturing</option>
                        <option value="technology">Technology</option>
                        <option value="healthcare">Healthcare</option>
                        <option value="food">Food & Hospitality</option>
                    </select>
                </div>
                <div>
                    <label for="location-filter" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #003366;">Location</label>
                    <select id="location-filter" style="width: 100%; padding: 0.8rem; border: 2px solid #E6F3FF; border-radius: 6px; font-size: 1rem;">
                        <option value="">All Locations</option>
                        <option value="downtown">Downtown</option>
                        <option value="north">North District</option>
                        <option value="south">South District</option>
                        <option value="east">East District</option>
                        <option value="west">West District</option>
                    </select>
                </div>
                <div>
                    <label for="denomination-filter" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #003366;">Denomination</label>
                    <select id="denomination-filter" style="width: 100%; padding: 0.8rem; border: 2px solid #E6F3FF; border-radius: 6px; font-size: 1rem;">
                        <option value="">All Denominations</option>
                        <% denominations.forEach(denom => { %>
                        <option value="<%= denom.id %>" <%= filters.denomination == denom.id ? 'selected' : '' %>><%= denom.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div>
                    <button id="search-btn" class="cta-button" style="width: 100%;">Search</button>
                </div>
            </div>
        </div>

        <!-- Directory View -->
        <div id="directory-view" class="view-container">
            <h3 style="text-align: center; margin-bottom: 2rem; color: #003366;">Member Business Directory</h3>
            <div id="directory-list" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2rem;">
                <% users.forEach(user => { %>
                <div class="directory-item" style="background: white; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,51,102,0.1); overflow: hidden;">
                    <div style="padding: 1.5rem;">
                        <div style="display: flex; align-items: center; margin-bottom: 1rem;">
                            <% if (user.profileImageUrl) { %>
                            <img src="<%= user.profileImageUrl %>" alt="<%= user.businessName || user.firstName %>" style="width: 60px; height: 60px; border-radius: 50%; margin-right: 1rem; object-fit: cover;">
                            <% } else { %>
                            <div style="width: 60px; height: 60px; border-radius: 50%; background: #E6F3FF; display: flex; align-items: center; justify-content: center; margin-right: 1rem; font-size: 1.5rem; color: #003366;">
                                <%= (user.businessName || user.firstName).charAt(0).toUpperCase() %>
                            </div>
                            <% } %>
                            <div>
                                <h4 style="margin: 0; color: #003366;"><%= user.businessName || (user.firstName + ' ' + user.lastName) %></h4>
                                <% if (user.denomination) { %>
                                <small style="color: #D4AF37;"><%= user.denomination.name %></small>
                                <% } %>
                            </div>
                        </div>
                        <% if (user.businessDescription) { %>
                        <p style="color: #666; margin-bottom: 1rem; line-height: 1.5;"><%= user.businessDescription %></p>
                        <% } %>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div style="display: flex; gap: 0.5rem;">
                                <% if (user.isVerified) { %>
                                <span style="background: #D4AF37; color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.8rem;">Verified</span>
                                <% } %>
                                <span style="background: #003366; color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.8rem;">Trust: <%= user.trustScore || 0 %></span>
                            </div>
                            <button class="cta-button" style="font-size: 0.9rem; padding: 0.5rem 1rem;" onclick="viewProfile('<%= user.id %>')">View Profile</button>
                        </div>
                    </div>
                </div>
                <% }) %>
                <% if (users.length === 0) { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: #666;">
                    <i class="fas fa-search" style="font-size: 3rem; margin-bottom: 1rem; color: #E6F3FF;"></i>
                    <p>No members found matching your criteria.</p>
                </div>
                <% } %>
            </div>
            <% if (pagination.totalPages > 1) { %>
            <div style="text-align: center; margin-top: 2rem;">
                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                <a href="?page=<%= i %><%= filters.q ? '&q=' + encodeURIComponent(filters.q) : '' %><%= filters.category ? '&category=' + filters.category : '' %><%= filters.location ? '&location=' + encodeURIComponent(filters.location) : '' %><%= filters.denomination ? '&denomination=' + filters.denomination : '' %><%= filters.sort ? '&sort=' + filters.sort : '' %>"
                   class="pagination-link <%= i === pagination.currentPage ? 'active' : '' %>">
                    <%= i %>
                </a>
                <% } %>
            </div>
            <% } %>
        </div>
    </div>
</section>