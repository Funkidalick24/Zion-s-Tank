<section class="hero">
    <div class="container">
        <h2>Member Business Directory</h2>
        <p>Connect with verified members and discover trusted business partners in your community.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <!-- Search and Filter Bar -->
        <div class="filter-panel">
            <div class="filter-grid">
                <div class="filter-field">
                    <label for="search-input">Search</label>
                    <input type="text" id="search-input" placeholder="Search businesses, products..." class="filter-control">
                </div>
                <div class="filter-field">
                    <label for="category-filter">Category</label>
                    <select id="category-filter" class="filter-control">
                        <option value="">All Categories</option>
                        <option value="retail">Retail & Services</option>
                        <option value="professional">Professional Services</option>
                        <option value="manufacturing">Manufacturing</option>
                        <option value="technology">Technology</option>
                        <option value="healthcare">Healthcare</option>
                        <option value="food">Food & Hospitality</option>
                    </select>
                </div>
                <div class="filter-field">
                    <label for="location-filter">Location</label>
                    <select id="location-filter" class="filter-control">
                        <option value="">All Locations</option>
                        <option value="downtown">Downtown</option>
                        <option value="north">North District</option>
                        <option value="south">South District</option>
                        <option value="east">East District</option>
                        <option value="west">West District</option>
                    </select>
                </div>
                <div class="filter-field">
                    <label for="denomination-filter">Denomination</label>
                    <select id="denomination-filter" class="filter-control">
                        <option value="">All Denominations</option>
                        <% denominations.forEach(denom => { %>
                        <option value="<%= denom.id %>" <%= filters.denomination == denom.id ? 'selected' : '' %>><%= denom.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="filter-field">
                    <button id="search-btn" class="cta-button filter-submit">Search</button>
                </div>
            </div>
        </div>

        <!-- Directory View -->
        <div id="directory-view" class="view-container">
            <h3 class="section-subheading">Member Business Directory</h3>
            <div id="directory-list" class="cards-grid cards-grid-lg">
                <% users.forEach(user => { %>
                <div class="directory-item showcase-card">
                    <div class="entity-header">
                            <% if (user.profileImageUrl) { %>
                            <img src="<%= user.profileImageUrl %>" alt="<%= user.businessName || user.firstName %>" class="avatar-md">
                            <% } else { %>
                            <div class="avatar-md avatar-fallback">
                                <%= (user.businessName || user.firstName).charAt(0).toUpperCase() %>
                            </div>
                            <% } %>
                            <div>
                                <h4 class="card-title"><%= user.businessName || (user.firstName + ' ' + user.lastName) %></h4>
                                <% if (user.denomination) { %>
                                <small class="card-meta"><%= user.denomination.name %></small>
                                <% } %>
                            </div>
                        </div>
                        <% if (user.businessDescription) { %>
                        <p class="card-copy"><%= user.businessDescription %></p>
                        <% } %>
                        <div class="card-actions">
                            <div class="pill-row">
                                <% if (user.isVerified) { %>
                                <span class="pill pill-verified">Verified</span>
                                <% } %>
                                <span class="pill pill-primary">Trust: <%= user.trustScore || 0 %></span>
                            </div>
                            <button class="cta-button button-sm" onclick="viewProfile('<%= user.id %>')">View Profile</button>
                        </div>
                </div>
                <% }) %>
                <% if (users.length === 0) { %>
                <div class="empty-state">
                    <i class="fas fa-search empty-icon"></i>
                    <p>No members found matching your criteria.</p>
                </div>
                <% } %>
            </div>
            <% if (pagination.totalPages > 1) { %>
            <div class="pagination-wrap">
                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                <a href="?page=<%= i %><%= filters.q ? '&q=' + encodeURIComponent(filters.q) : '' %><%= filters.category ? '&category=' + filters.category : '' %><%= filters.location ? '&location=' + encodeURIComponent(filters.location) : '' %><%= filters.denomination ? '&denomination=' + filters.denomination : '' %><%= filters.sort ? '&sort=' + filters.sort : '' %>"
                   class="pagination-link <%= i === pagination.currentPage ? 'active' : '' %>">
                    <%= i %>
                </a>
                <% } %>
            </div>
            <% } %>
        </div>
    </div>
</section>
